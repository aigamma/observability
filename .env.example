# Fleet collector configuration. Copy to .env for local notes only; in
# production these are set as Fly secrets (never committed):
#   fly secrets set GRAFANA_CLOUD_OTLP_ENDPOINT=... GRAFANA_CLOUD_INSTANCE_ID=... GRAFANA_CLOUD_API_TOKEN=...

# Grafana Cloud OTLP gateway (from Grafana Cloud > Connections > OTLP).
# Looks like: https://otlp-gateway-prod-us-east-0.grafana.net/otlp
GRAFANA_CLOUD_OTLP_ENDPOINT=

# Grafana Cloud OTLP basic-auth: the numeric instance ID is the username,
# a Cloud Access Policy token (scope: metrics/logs/traces write) is the password.
GRAFANA_CLOUD_INSTANCE_ID=
GRAFANA_CLOUD_API_TOKEN=

# Shared secret every service presents to push telemetry (Authorization: Bearer ...).
# Hardening step; see docs/ONBOARDING.md. Left blank = receivers accept unauthenticated.
ALLOY_INGEST_BEARER=
